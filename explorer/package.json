{
  "name": "arena-explorer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:local": "VITE_API_ENV=local vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:staging": "VITE_API_ENV=staging vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc && vite build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "description": "Generic Are.na client built on @aredotna/sdk",
  "dependencies": {
    "@aredotna/icons": "^0.2.0",
    "@aredotna/react-query": "^0.0.4",
    "@aredotna/sdk": "^0.0.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/react-query": "^5.90.5",
    "react": "^18.2.0",
    "react-blurhash": "^0.3.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0"
  },
  "packageManager": "pnpm@11.0.8"
}
