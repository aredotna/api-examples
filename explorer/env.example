# API Environment
# Options: 'production' | 'staging' | 'local'
VITE_API_ENV=production

# OAuth Configuration
# Get these values after registering your OAuth application with Are.na
VITE_OAUTH_CLIENT_ID=your_client_id_here

# Optional: Override the default redirect URI
# Default is: {window.location.origin}/oauth/callback
# VITE_OAUTH_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback
