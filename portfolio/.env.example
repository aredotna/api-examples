# Public Are.na root channel. Blocks in this channel render on the home page;
# channels in this channel become persistent top-level navigation.
ARENA_CHANNEL_SLUG=arena-influences

# Optional: point at a local or staging API while developing.
ARENA_API_BASE_URL=https://api.are.na

# Used for canonical URLs, Open Graph tags, and RSS links.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:5175
